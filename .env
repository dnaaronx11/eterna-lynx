# Environment
NODE_ENV=development
DEPLOY_ENV=local

# Core API Gateway
GATEWAY_PORT=80
GATEWAY_HOST=localhost

# PostgreSQL
DB_HOST=postgres_db
DB_PORT=5432
DB_USER=eternalynx_admin
DB_PASSWORD=SuperSecurePassword123! @#
DB_NAME=eternadb

# Redis
REDIS_HOST=redis_cache
REDIS_PORT=6379

# Kafka
KAFKA_BROKER=kafka_broker: 9092
KAFKA_TOPIC_FINANCE=finance_tx_queue
KAFKA_TOPIC_AI=ai_job_queue
KAFKA_TOPIC_MARKET=market_events

# JWT & Security
JWT_SECRET_KEY=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRATION=24h
CORS_ORIGIN=http://localhost:3000

# AI Services
AI_ORCHESTRATOR_URL=http://quantum-nexus: 8081
OPENAI_API_KEY=sk-your-openai-key-here
ANTHROPIC_API_KEY=sk-your-anthropic-key-here

# Blockchain
GUARDIAN_CHAIN_RPC=http://guardian_chain_node:8545
VELOCITY_CHAIN_RPC=http://velocity_chain_node:8545
CONTRACT_DIGICOIN_ADDRESS=0x... 
CONTRACT_UNICOIN_ADDRESS=0x... 

# VaultLynX & Security
BIOMETRIC_ENABLED=true
STEGANOGRAPHY_ENABLED=true
KEY_ROTATION_HOURS=24

# Logging
LOG_LEVEL=info
